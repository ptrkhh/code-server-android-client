<?xml version="1.0" encoding="utf-8"?>
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">
    <shortcut
        android:shortcutId="new_window"
        android:enabled="true"
        android:icon="@mipmap/ic_launcher"
        android:shortcutShortLabel="@string/new_window">
        <!-- trampoline re-launches MainActivity with multi-instance flags in code -->
        <intent
            android:action="android.intent.action.MAIN"
            android:targetPackage="com.term.codeserver"
            android:targetClass="com.term.codeserver.NewWindowActivity" />
    </shortcut>
</shortcuts>
